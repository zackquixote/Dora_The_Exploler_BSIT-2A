+<?php
+
+namespace App\Controllers;
+
+use App\Models\ResidentModel;
+use App\Services\IdCardService;
+use App\Services\TokenService;
+use CodeIgniter\Test\CIUnitTestCase;
+use CodeIgniter\Test\ControllerTestTrait;
+
+final class IdGeneratorTest extends CIUnitTestCase
+{
+    use ControllerTestTrait;
+
+    public function testVerifyAcceptsMatchingResidentToken(): void
+    {
+        $resident = [
+            'id' => 5,
+            'first_name' => 'Jane',
+            'last_name' => 'Doe',
+            'sex' => 'female',
+            'sitio' => 'Purok 1',
+            'status' => 'active',
+        ];
+
+        $tokenService = new TokenService('jwt_secret_789', 'enc');
+        $service = new IdCardService($this->residentModelStub($resident), $tokenService);
+        $jwt = $tokenService->generateJwtToken(5, 60);
+
+        $result = $this->withURI('http://localhost/verify/5/' . $jwt)
+            ->controller(IdGenerator::class);
+
+        $controllerProperty = new \ReflectionProperty(IdGenerator::class, 'service');
+        $controllerProperty->setAccessible(true);
+        $controllerProperty->setValue($this->controller, $service);
+
+        $response = $this->execute('verify', 5, $jwt);
+
+        $this->assertTrue($response->isOK());
+        $this->assertStringContainsString('Verified Record', $response->getBody());
+        $this->assertStringContainsString('Jane Doe', $response->getBody());
+    }
+
+    public function testVerifyRejectsTokenForAnotherResident(): void
+    {
+        $resident = [
+            'id' => 5,
+            'first_name' => 'Jane',
+            'last_name' => 'Doe',
+            'sex' => 'female',
+            'sitio' => 'Purok 1',
+            'status' => 'active',
+        ];
+
+        $tokenService = new TokenService('jwt_secret_789', 'enc');
+        $service = new IdCardService($this->residentModelStub($resident), $tokenService);
+        $jwt = $tokenService->generateJwtToken(99, 60);
+
+        $result = $this->withURI('http://localhost/verify/5/' . $jwt)
+            ->controller(IdGenerator::class);
+
+        $controllerProperty = new \ReflectionProperty(IdGenerator::class, 'service');
+        $controllerProperty->setAccessible(true);
+        $controllerProperty->setValue($this->controller, $service);
+
+        $response = $this->execute('verify', 5, $jwt);
+
+        $this->assertTrue($response->isOK());
+        $this->assertStringContainsString('Invalid or expired verification token.', $response->getBody());
+    }
+
+    private function residentModelStub(array $resident): ResidentModel
+    {
+        return new class ($resident) extends ResidentModel {
+            public function __construct(private array $resident)
+            {
+            }
+
+            public function getDetailsWithHousehold($id)
+            {
+                return (int) $id === (int) $this->resident['id'] ? $this->resident : null;
+            }
+        };
+    }
+}
