# Disable directory browsing
Options -Indexes

# ----------------------------------------------------------------------
# Rewrite engine
# ----------------------------------------------------------------------

<IfModule mod_rewrite.c>
    Options +FollowSymlinks
    RewriteEngine On

    # If CodeIgniter is in a subfolder, set the folder name here.
    # If it's directly inside /var/www/html, then just use /
    RewriteBase /empower-brgy/

    # If the requested URL is not a file or directory, redirect it to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php/$1 [L]

    # Rewrite "www.example.com -> example.com"
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
    RewriteRule ^ http://%1%{REQUEST_URI} [R=301,L]

    # Send all non-file/directory requests to index.php
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php/$1 [L]

    # Ensure Authorization header is passed along
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

<IfModule !mod_rewrite.c>
    ErrorDocument 404 index.php
</IfModule>

# Disable server signature
ServerSignature Off

# ======================================================================
# GZIP COMPRESSION - Fixes slow TTFB (Document Latency)
# ======================================================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
    
    # Remove problematic browsers from compression
    BrowserMatch ^Mozilla/4 ^$
    BrowserMatch ^Mozilla/4\.0[678] no-gzip
    BrowserMatch \bMSIE !no-gzip !gzip-only-text/html
    BrowserMatch \bMSI[E] !no-gzip !gzip-only-text/html
    BrowserMatch \bOpera !no-gzip !gzip-only-text/html
</IfModule>

# ======================================================================
# BROWSER CACHING - Fixes Cache insight (5.4MB wasted on repeat visits)
# ======================================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault "access plus 1 week"
    
    # Images: 30 days
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/gif "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    
    # CSS & JS: 30 days (versioned in queries)
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType text/javascript "access plus 30 days"
    
    # Fonts: 1 year
    ExpiresByType application/x-font-ttf "access plus 1 year"
    ExpiresByType application/x-font-otf "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
    ExpiresByType application/vnd.ms-fontobject "access plus 1 year"
    
    # HTML: 1 week (to catch updates)
    ExpiresByType text/html "access plus 1 week"
</IfModule>

# ======================================================================
# CACHE CONTROL HEADERS (fallback if mod_expires not available)
# ======================================================================
<IfModule mod_headers.c>
    # Cache static assets for a month
    <FilesMatch "\.(jpg|jpeg|png|gif|ico|webp|svg|woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "max-age=2592000, public"
        Header set Pragma "public"
    </FilesMatch>
    
    # Cache CSS & JS for 30 days
    <FilesMatch "\.(css|js)$">
        Header set Cache-Control "max-age=2592000, public"
        Header set Pragma "public"
    </FilesMatch>
    
    # Don't cache HTML pages (must validate)
    <FilesMatch "\.(html|htm|php)$">
        Header set Cache-Control "max-age=604800, must-revalidate, public"
        Header set Pragma "public"
    </FilesMatch>
    
    # Remove sensitive headers for security
    Header unset X-Powered-By
    Header unset Server
    Header set X-Content-Type-Options "nosniff"
</IfModule>
